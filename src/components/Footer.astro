<style>
  .footer {
    background-color: #1a1a1a;
    color: #e0e0e0;
    padding: var(--spacing-lg) 0 2rem;
    margin-top: auto;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-sm);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-md);
  }
  .footer h3 {
    color: #fff;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-sm);
  }
  .footer h4 {
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-sans);
  }
  .footer ul {
    list-style: none;
  }
  .footer li {
    margin-bottom: 0.5rem;
  }
  .footer a {
    color: #aaa;
  }
  .footer a:hover {
    color: #fff;
  }
  .footer-bottom {
    text-align: center;
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-md);
    border-top: 1px solid #333;
    font-size: 0.85rem;
    color: #777;
  }
</style>
